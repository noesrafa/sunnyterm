{
  "name": "sunnyterm",
  "productName": "SunnyTerm",
  "version": "0.5.0",
  "description": "Infinite canvas terminal emulator",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite dev",
    "dist": "electron-vite build && electron-builder --mac --arm64 --x64",
    "dist:arm64": "electron-vite build && electron-builder --mac --arm64",
    "dist:x64": "electron-vite build && electron-builder --mac --x64"
  },
  "keywords": [
    "terminal",
    "electron",
    "canvas"
  ],
  "license": "MIT",
  "build": {
    "appId": "com.sunnyterm.app",
    "productName": "SunnyTerm",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "resources/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "dmg": {
      "title": "SunnyTerm",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  },
  "devDependencies": {
    "@electron-toolkit/utils": "^4.0.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "lucide-react": "^0.577.0",
    "postcss": "^8.4.49",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "zustand": "^5.0.12"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "shiki": "^4.0.2",
    "sonner": "^2.0.7"
  },
  "type": "module"
}
